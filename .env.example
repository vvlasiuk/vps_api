# Для роботи скопіюйте .env.example у .env і відредагуйте значення під свою конфігурацію
DB_USER=root
DB_PASS=password
DB_HOST=localhost
DB_PORT=3306

DB_NAME=vps_db

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_INPUT_QUEUE=input.events
RABBITMQ_ERROR_QUEUE=sys_error.queue
RABBITMQ_VHOST=/

# 1C
ONEC_BASE_URL=""
ONEC_TOKEN=""
ONEC_SOURCE_NAME="1C_UTP"
ONEC_PHOTOS_DIR="D:/vps_photos"
ONEC_CF_MODULE_MANIFEST=""

# AI
AI_PROVIDER=gemini              # активний провайдер: gemini | anthropic
AI_MODEL=                       # необов'язк.: перевизначити модель; порожнє → дефолт провайдера
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-2.5-flash-lite
GOOGLE_API_VERSION=v1beta
ANTHROPIC_API_KEY=...
ANTHROPIC_MODEL=claude-sonnet-4-5

# BACKUP
BACKUP_DIR="D:/backups_vps"
BACKUP_TEMP_DAYS=30
